        <mxCell id="f11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=none;strokeColor=#999999;" edge="1" parent="1" source="forked_browser" target="base_ctx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f11_lbl" value="forked from, never writes back" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1050" y="615" width="180" height="20" as="geometry" />
        </mxCell>

        <mxCell id="note2" value="Why fork instead of mounting base directly?&#10;• Lexmount only supports read_write mode; a single session on base context would lock it, blocking parallel evals.&#10;• Fork is a cheap copy-on-create; each parallel task forks its own throwaway.&#10;• Fork is deleted in LexmountBackend.close() (also on SIGKILL via orphan_cleanup) — no storage bloat.&#10;• The base context is touched exactly once (Phase 1 login); cookies/localStorage persist indefinitely." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="650" width="700" height="140" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
