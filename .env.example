# ============================================================================
# BrowserUse Bench environment variables
# ============================================================================

## API settings
# ----------------------------------------------------------------------------

### OpenAI API
OPENAI_API_KEY=your-openai-api-key-here        # OpenAI API key
# OPENAI_BASE_URL=https://api.openai.com/v1    # Optional: custom / OpenAI-compatible gateway

### OpenAI-compatible gateway (Skyvern, and any agent using openai_compatible_*)
# OPENAI_COMPATIBLE_API_KEY=your-gateway-api-key
# OPENAI_COMPATIBLE_API_BASE=https://your-gateway.example.com/v1

### Anthropic API (Claude Code agent)
ANTHROPIC_API_KEY=your-anthropic-api-key-here  # Anthropic API key
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # Optional: custom base URL

### Lexmount API
LEXMOUNT_API_KEY=your-lexmount-api-key         # Lexmount service key
LEXMOUNT_PROJECT_ID=your-project-id            # Project ID
# LEXMOUNT_BASE_URL=https://api.lexmount.cn    # Optional: override Lexmount API base URL. Official endpoints:
#   https://api.lexmount.cn               — production (mainland China / 国内)
#   https://api.lexmount.com              — production (international / 国外)
#   https://apitest.local.lexmount.net    — staging / test

### Browser Use API
BROWSER_USE_API_KEY=your-browser-use-api-key   # Browser Use service key

### AgentBay API (only when browser_id: agentbay)
# AGENTBAY_API_KEY=your-agentbay-api-key       # Alibaba Cloud AgentBay service key

### HuggingFace (Optional)
# HF_ENDPOINT=https://hf-mirror.com          # Use mirror for faster downloads in China

